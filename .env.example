# ─── Application ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/exam_db
SYNC_DATABASE_URL=postgresql://postgres:your_password@localhost:5432/exam_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI — Gemini ──────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── PostgreSQL (for Docker Compose) ─────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=exam_db

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── GitHub Actions Secrets (set in repo settings, NOT here) ──────────────────
# SERVER_HOST=your.production.server.com
# SERVER_USER=ubuntu
# SSH_KEY=<your private SSH key>
